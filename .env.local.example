# Supabase — get these from your Supabase project dashboard (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Your deployed URL (used for OAuth redirects). Leave blank for localhost.
NEXT_PUBLIC_SITE_URL=

# Vercel cron authentication (generate a random secret)
CRON_SECRET=

# Unsplash (used only for the seed script — not deployed)
UNSPLASH_ACCESS_KEY=
